*.egg
MANIFEST

# PyCharm
.idea/
*.iml
*.iws

# VS Code Python
.vscode/
*.code-workspace

# Jupyter Notebook
.ipynb_checkpoints/
*.ipynb

# Poetry
poetry.lock

# ─────────────────────────────────────────────────────────────────────────
# Unity
# ─────────────────────────────────────────────────────────────────────────

# Unity Library and Logs (large generated files)
FYP_Hand_Viz/Library/
FYP_Hand_Viz/Logs/
FYP_Hand_Viz/Temp/
FYP_Hand_Viz/obj/
FYP_Hand_Viz/.vscode/

# Build results
FYP_Hand_Viz/Builds/
FYP_Hand_Viz/Build/

# Generated Visual Studio solution
FYP_Hand_Viz/.vs/
FYP_Hand_Viz/*.csproj
FYP_Hand_Viz/*.csproj.user
FYP_Hand_Viz/*.sln

# User-specific preferences (but keep project settings)
FYP_Hand_Viz/UserSettings/

# Rider
FYP_Hand_Viz/.idea/
FYP_Hand_Viz/Assets/Plugins/GitHub/Editor.meta
FYP_Hand_Viz/Assets/Plugins/GitHub.meta

# ─────────────────────────────────────────────────────────────────────────
# RoFormer Communication Pipeline
# ─────────────────────────────────────────────────────────────────────────

# Generated outputs
RoFormer_Communication_Pipeline/emg_preprocess.png
RoFormer_Communication_Pipeline/predictions.png
RoFormer_Communication_Pipeline/*.txt
RoFormer_Communication_Pipeline/output/
RoFormer_Communication_Pipeline/results/

# Cache
RoFormer_Communication_Pipeline/__pycache__/
RoFormer_Communication_Pipeline/.pytest_cache/

# Data (optional - uncomment if you want to exclude)
# RoFormer_Communication_Pipeline/*.mat
# RoFormer_Communication_Pipeline/data/

# Model checkpoints (too large to commit, should download)
RoFormer_Communication_Pipeline/roformer.pt
RoFormer_Communication_Pipeline/*.pt
RoFormer_Communication_Pipeline/checkpoints/

